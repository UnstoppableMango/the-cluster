{
  "name": "THECLUSTER",
  "dockerComposeFile": [
    "docker-compose.yaml",
    "docker-compose.override.yaml",
    "../clusters/rosequartz/ci/docker-compose.yaml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspaces",
  "containerEnv": {
    "DEVCONTAINER": "true"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  }
}
