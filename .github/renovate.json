{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"github>UnstoppableMango/renovate-config",
		"schedule:weekly"
	],
	"ignorePaths": [
		"**/node_modules/**",
		"**/vendor/**",
		"**/testdata/**",
		"charts/**",
		"clusters/**",
		"crds/**",
		"infra/crds/**",
		"lib/**",
		"flux/**/crds/**"
	],
	"ignoreDeps": [
		"@pulumi/crds",
		"@unstoppablemango/thecluster",
		"@unstoppablemango/thecluster-crds"
	],
	"major": {
		"dependencyDashboardApproval": true
	},
	"kubernetes": {
		"managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
	},
	"flux": {
		"managerFilePatterns": ["/flux/.+\\.ya?ml$/"]
	},
	"customManagers": [
		{
			"customType": "regex",
			"managerFilePatterns": [
				"/nix/.+\\.nix$/"
			],
			"matchStrings": [
				"github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/(?<currentValue>v[\\d.]+)/"
			],
			"datasourceTemplate": "github-releases"
		}
	],
	"packageRules": [
		{
			"matchPackageNames": [
				"cert-manager",
				"cert-manager/cert-manager"
			],
			"groupName": "cert-manager"
		},
		{
			"matchPackageNames": [
				"ghcr.io/nginx/charts/nginx-gateway-fabric",
				"ghcr.io/nginx/nginx-gateway-fabric",
				"ghcr.io/nginx/nginx-gateway-fabric/nginx"
			],
			"groupName": "nginx-gateway-fabric"
		},
		{
			"matchPackageNames": [
				"harbor",
				"/^goharbor\\/.*/"
			],
			"groupName": "harbor"
		},
		{
			"matchPackageNames": [
				"/bitnami\\/sealed-secrets-controller/",
				"/bitnami-labs\\/sealed-secrets/"
			],
			"groupName": "sealed-secrets"
		},
		{
			"matchPackageNames": [
				"external-dns",
				"kubernetes-sigs/external-dns",
				"registry.k8s.io/external-dns/external-dns"
			],
			"groupName": "external-dns"
		},
		{
			"matchPackageNames": [
				"cloudflare/origin-ca-issuer"
			],
			"groupName": "origin-ca-issuer"
		},
		{
			"matchPackageNames": ["xpkg.crossplane.io/crossplane/crossplane", "crossplane"],
			"groupName": "crossplane"
		},
		{
			"matchPackageNames": ["ghcr.io/renovatebot/renovate"],
			"matchUpdateTypes": ["patch"],
			"enabled": false
		},
		{
			"matchPackageNames": [
				"ghcr.io/renovatebot/renovate",
				"renovate"
			],
			"groupName": "renovate",
			"automerge": true
		},
		{
			"matchPackageNames": [
				"gitea",
				"docker.gitea.com/gitea"
			],
			"groupName": "gitea"
		},
		{
			"matchPackageNames": [
				"pihole",
				"pihole/pihole"
			],
			"groupName": "pihole"
		},
		{
			"matchPackageNames": [
				"cloudflare-tunnel-ingress-controller",
				"ghcr.io/strrl/cloudflare-tunnel-ingress-controller"
			],
			"groupName": "cloudflare-tunnel-ingress-controller"
		},
		{
			"matchPackageNames": [
				"cloudnative-pg",
				"ghcr.io/cloudnative-pg/cloudnative-pg"
			],
			"groupName": "cnpg"
		},
		{
			"matchPackageNames": [
				"metrics-server",
				"registry.k8s.io/metrics-server/metrics-server"
			],
			"groupName": "metrics-server"
		},
		{
			"matchPackageNames": [
				"nats"
			],
			"groupName": "nats"
		},
		{
			"matchPackageNames": [
				"velero",
				"velero/velero"
			],
			"groupName": "velero"
		},
		{
			"matchPackageNames": [
				"ghcr.io/actions/actions-runner-controller-charts/gha-runner-scale-set-controller",
				"ghcr.io/actions/gha-runner-scale-set-controller"
			],
			"groupName": "arc"
		}
	]
}
